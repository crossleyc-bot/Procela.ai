# Demo form email delivery (AWS SES)
# Copy to .env.local for local development, or set these in the Amplify console.

# Verified SES sender identity (email or domain must be verified in SES).
SES_FROM_EMAIL=no-reply@procela.ai

# Where demo requests are delivered.
DEMO_TO_EMAIL=sales@procela.ai

# SES region. Falls back to AWS_REGION, then us-east-1.
SES_REGION=us-east-1

# AWS credentials are resolved from the standard provider chain:
#  - Locally: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (or a shared profile).
#  - On Amplify: the compute role — grant it ses:SendEmail (no keys needed).
# Only set these locally if you are not using a shared AWS profile:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
