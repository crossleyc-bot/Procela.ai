# Demo form email delivery (Resend)
# Copy to .env.local for local development, or set these in the Amplify console.

# Resend API key - create at https://resend.com (API Keys section).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address for the demo notification.
# Must be on a domain you have verified in Resend.
# A display name is optional, e.g. "Procela <no-reply@procela.ai>".
DEMO_FROM_EMAIL=no-reply@procela.ai

# Where demo requests are delivered.
DEMO_TO_EMAIL=sales@procela.ai
